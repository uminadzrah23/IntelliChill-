  </div>

  <!-- FIREBASE SDK -->
  <script type="module">
    import { initializeApp } from "https://www.gstatic.com/firebasejs/10.11.0/firebase-app.js";
    import { getFirestore, collection, getDocs, onSnapshot } from "https://www.gstatic.com/firebasejs/10.11.0/firebase-firestore.js";

    const firebaseConfig = {
      apiKey:            "AIzaSyCH3exGIRj84tezVtgKJ9U93ERa6ubgE-w",
      authDomain:        "intellichill.firebaseapp.com",
      projectId:         "intellichill",
      storageBucket:     "intellichill.firebasestorage.app",
      messagingSenderId: "388845708926",
      appId:             "1:388845708926:web:650f54cee14a5312cf1a2f"
    };

    const app = initializeApp(firebaseConfig);
    const db  = getFirestore(app);
    const COLLECTION = "food_id";

    let lastRefresh = Date.now();
    let refreshCounter = 0;
    let logEntries = [];
    let foodItems = [];

    // ── CLOCK ──
    function updateClock() {
      const now = new Date();
      document.getElementById('nav-time').textContent = now.toTimeString().slice(0,8);
      const ago = Math.floor((Date.now() - lastRefresh) / 1000);
      document.getElementById('stat-refresh').textContent = ago;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // ── EMOJI LOOKUP ──
    function getFoodEmoji(name) {
      const n = (name||'').toLowerCase();
      if (n.includes('apple'))    return '🍎';
      if (n.includes('banana'))   return '🍌';
      if (n.includes('orange'))   return '🍊';
      if (n.includes('grape'))    return '🍇';
      if (n.includes('strawb'))   return '🍓';
      if (n.includes('mango'))    return '🥭';
      if (n.includes('milk'))     return '🥛';
      if (n.includes('egg'))      return '🥚';
      if (n.includes('bread'))    return '🍞';
      if (n.includes('carrot'))   return '🥕';
      if (n.includes('broccoli')) return '🥦';
      if (n.includes('tomato'))   return '🍅';
      if (n.includes('chicken'))  return '🍗';
      if (n.includes('fish'))     return '🐟';
      if (n.includes('rice'))     return '🍚';
      if (n.includes('cheese'))   return '🧀';
      return '🥫';
    }

    // ── STATUS ──
    function getStatus(expiryDateStr) {
      if (!expiryDateStr) return { label:'No Expiry', cls:'soon', days:0 };
      const today = new Date(); today.setHours(0,0,0,0);
      const expiry = new Date(expiryDateStr);
      const diff = Math.ceil((expiry - today) / 86400000);
      if (diff < 0)  return { label:'Expired',       cls:'expired', days:diff };
      if (diff <= 3) return { label:'Expiring Soon', cls:'soon',    days:diff };
      return               { label:'Fresh',          cls:'fresh',   days:diff };
    }

    // ── ADD LOG ENTRY ──
    function addLog(type, msg) {
      const now = new Date().toTimeString().slice(0,8);
      logEntries.unshift({ time: now, type, msg });
      if (logEntries.length > 50) logEntries.pop();
      renderLog();
    }

    function renderLog() {
      const body = document.getElementById('log-body');
      body.innerHTML = logEntries.map(e => {
        const highlighted = e.msg.replace(/\[([^\]]+)\]/g, '<span class="highlight">[$1]</span>');
        return `<div class="log-entry">
          <span class="log-time">${e.time}</span>
          <span class="log-type ${e.type}">${e.type}</span>
          <span class="log-msg">${highlighted}</span>
        </div>`;
      }).join('');
    }

    // ── ANIMATE FLOW ──
    function animateFlow() {
      const nodes = ['node-pi','node-flask','node-yolo','node-firebase','node-dash'];
      const lines = ['line-1','line-2','line-3','line-4'];
      const delays = [0, 400, 800, 1200, 1600];
      const lineDelays = [200, 600, 1000, 1400];
      const times = ['12ms','118ms','340ms','45ms'];

      nodes.forEach((id, i) => {
        setTimeout(() => {
          const el = document.getElementById(id);
          el.classList.add('active');
          setTimeout(() => el.classList.remove('active'), 1000);
        }, delays[i]);
      });

      lines.forEach((id, i) => {
        setTimeout(() => {
          const el = document.getElementById(id);
          document.getElementById(`ms-${i+1}`).textContent = times[i];
          el.classList.add('active');
          setTimeout(() => el.classList.remove('active'), 800);
        }, lineDelays[i]);
      });
    }

    // ── RENDER FIREBASE ITEMS ──
    function renderFirebaseItems() {
      const body = document.getElementById('firebase-body');
      if (foodItems.length === 0) {
        body.innerHTML = '<div class="mono-loading">No items in Firestore</div>';
        return;
      }
      body.innerHTML = foodItems.map(item => {
        const st = getStatus(item.expiryDate);
        const emoji = getFoodEmoji(item.name);
        const expiry = item.expiryDate || 'N/A';
        return `<div class="firebase-item">
          <div class="firebase-emoji">${emoji}</div>
          <div class="firebase-info">
            <div class="firebase-name">${item.name}</div>
            <div class="firebase-meta">expiry: ${expiry} · ${st.days < 0 ? Math.abs(st.days)+'d ago' : st.days+'d left'}</div>
          </div>
          <div class="firebase-badge ${st.cls}">${st.label.toUpperCase()}</div>
        </div>`;
      }).join('');
    }

    // ── RENDER CONFIDENCE (simulated from last detected food) ──
    function renderConfidence(foodName) {
      if (!foodName) return;
      const body = document.getElementById('conf-body');
      // Simulated confidence scores for detected food
      const conf1 = Math.floor(75 + Math.random() * 20);
      const conf2 = Math.floor(40 + Math.random() * 30);
      const conf3 = Math.floor(10 + Math.random() * 25);
      body.innerHTML = `
        <div style="flex:1;">
          <div style="display:flex;flex-direction:column;gap:10px;width:100%">
            <div class="conf-body" style="padding:0;gap:1rem;">
              <div class="conf-label">${foodName}</div>
              <div class="conf-bar-wrap"><div class="conf-bar" style="width:0%" data-w="${conf1}%"></div></div>
              <div class="conf-pct">${conf1}%</div>
            </div>
            <div class="conf-body" style="padding:0;gap:1rem;">
              <div class="conf-label">Unknown</div>
              <div class="conf-bar-wrap"><div class="conf-bar" style="width:0%;background:linear-gradient(90deg,#4cc9f0,#4361ee)" data-w="${conf2}%"></div></div>
              <div class="conf-pct" style="color:#4cc9f0">${conf2}%</div>
            </div>
            <div class="conf-body" style="padding:0;gap:1rem;">
              <div class="conf-label">Other</div>
              <div class="conf-bar-wrap"><div class="conf-bar" style="width:0%;background:linear-gradient(90deg,#c77dff,#9d4edd)" data-w="${conf3}%"></div></div>
              <div class="conf-pct" style="color:#c77dff">${conf3}%</div>
            </div>
          </div>
        </div>`;
      // Animate bars
      setTimeout(() => {
        document.querySelectorAll('.conf-bar[data-w]').forEach(b => {
          b.style.width = b.dataset.w;
        });
      }, 100);
    }

    // ── LOAD FIREBASE DATA ──
    async function loadData() {
      try {
        addLog('INFO', 'Querying Firestore collection [food_id]...');
        const snapshot = await getDocs(collection(db, COLLECTION));

        foodItems = snapshot.docs.map(d => {
          const data = d.data();
          return {
            id:         d.id,
            name:       data.food_name        || 'Unknown',
            dateAdded:  data.date_added       || '',
            expiryDate: data.estimated_expiry || data.expiry_date || ''
          };
        });

        lastRefresh = Date.now();
        refreshCounter++;

        const fresh   = foodItems.filter(i => getStatus(i.expiryDate).cls === 'fresh').length;
        const soon    = foodItems.filter(i => getStatus(i.expiryDate).cls === 'soon').length;
        const expired = foodItems.filter(i => getStatus(i.expiryDate).cls === 'expired').length;
        const alerts  = soon + expired;

        // Update stats
        document.getElementById('stat-total').textContent = foodItems.length;
        document.getElementById('stat-sub').textContent = `${fresh} fresh · ${soon} soon · ${expired} expired`;
        document.getElementById('stat-refresh-time').textContent = new Date().toTimeString().slice(0,8);
        document.getElementById('stat-alerts').textContent = alerts;
        document.getElementById('stat-alert-detail').textContent =
          alerts === 0 ? 'All items OK' : `${expired} expired · ${soon} expiring soon`;

        const alertDot = document.getElementById('alert-dot');
        alertDot.style.background = expired > 0 ? 'var(--red)' : soon > 0 ? 'var(--yellow)' : 'var(--green)';

        addLog('OK', `Firestore read complete — [${foodItems.length}] documents fetched`);
        addLog('DATA', `Fresh: [${fresh}]  Soon: [${soon}]  Expired: [${expired}]`);

        renderFirebaseItems();

        // Show confidence for last item
        if (foodItems.length > 0) {
          const last = foodItems[foodItems.length - 1];
          renderConfidence(last.name);
          addLog('INFO', `Last item in DB: [${last.name}] · expiry: [${last.expiryDate || 'N/A'}]`);
        }

        // Animate flow
        animateFlow();
        addLog('OK', 'System flow: Pi → Flask → YOLO → Firebase → Dashboard ✓');

      } catch (err) {
        addLog('ERROR', 'Firebase read failed: ' + err.message);
        document.getElementById('firebase-body').innerHTML =
          '<div class="mono-loading" style="color:var(--red)">⚠️ Firebase connection error</div>';
      }
    }

    // ── REAL-TIME LISTENER ──
    // This fires instantly whenever Firebase data changes!
    onSnapshot(collection(db, COLLECTION), (snapshot) => {
      addLog('INFO', `[Firebase] Real-time update received — [${snapshot.docs.length}] documents`);
      loadData();
    });

    // Initial load
    addLog('INFO', 'IntelliChill System Monitor initialising...');
    addLog('INFO', 'Connecting to Firebase project [intellichill]...');
    loadData();

    // Simulate Flask ping every 15s
    setInterval(() => {
      addLog('INFO', 'Pinging Flask API at [ngrok endpoint]...');
      setTimeout(() => {
        // We can't actually ping ngrok from here without T2 running
        addLog('WARN', 'Flask ping — T2 must be running ngrok for scan to work');
      }, 800);
    }, 15000);
  </script>

</body>
