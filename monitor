        </div>
        <div class="flow-node">
          <div class="flow-icon" id="node-flask">🌐</div>
          <div class="flow-label">FLASK API</div>
          <div class="flow-sublabel">T2 Backend</div>
        </div>
        <div class="flow-arrow">
          <div class="flow-line" id="line-2"></div>
          <div class="flow-ms" id="ms-2">—</div>
        </div>
        <div class="flow-node">
          <div class="flow-icon" id="node-yolo">🤖</div>
          <div class="flow-label">YOLO AI</div>
          <div class="flow-sublabel">T1 Model</div>
        </div>
        <div class="flow-arrow">
          <div class="flow-line" id="line-3"></div>
          <div class="flow-ms" id="ms-3">—</div>
        </div>
        <div class="flow-node">
          <div class="flow-icon" id="node-firebase">🔥</div>
          <div class="flow-label">FIREBASE</div>
          <div class="flow-sublabel">T3 Database</div>
        </div>
        <div class="flow-arrow">
          <div class="flow-line" id="line-4"></div>
          <div class="flow-ms" id="ms-4">—</div>
        </div>
        <div class="flow-node">
          <div class="flow-icon" id="node-dash">📊</div>
          <div class="flow-label">DASHBOARD</div>
          <div class="flow-sublabel">T4 Frontend</div>
        </div>
      </div>
    </div>

    <!-- ── STAT CARDS ── -->
    <div class="panel stat-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">📦</span> TOTAL ITEMS</div>
        <div class="status-dot green"></div>
      </div>
      <div class="stat-body">
        <div class="stat-value" id="stat-total">—</div>
        <div class="stat-label">IN FIREBASE</div>
        <div class="stat-sub" id="stat-sub">Loading...</div>
      </div>
    </div>

    <div class="panel stat-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">🔄</span> LAST REFRESH</div>
        <div class="status-dot green"></div>
      </div>
      <div class="stat-body">
        <div class="stat-value" id="stat-refresh">—</div>
        <div class="stat-label">SECONDS AGO</div>
        <div class="stat-sub" id="stat-refresh-time">Waiting...</div>
      </div>
    </div>

    <div class="panel stat-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">⚠️</span> ALERTS</div>
        <div class="status-dot" id="alert-dot" style="background:var(--muted)"></div>
      </div>
      <div class="stat-body">
        <div class="stat-value" id="stat-alerts">—</div>
        <div class="stat-label">ACTIVE ALERTS</div>
        <div class="stat-sub" id="stat-alert-detail">Checking...</div>
      </div>
    </div>

    <!-- ── API LOG ── -->
    <div class="panel log-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">📡</span> SYSTEM LOG</div>
        <div class="panel-title" style="gap:6px;">
          <div class="status-dot green"></div>
          <span style="font-size:0.65rem;">LIVE</span>
        </div>
      </div>
      <div class="log-body" id="log-body">
        <div class="mono-loading">Initialising system log...</div>
      </div>
    </div>

    <!-- ── FIREBASE DATA ── -->
    <div class="panel firebase-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">🔥</span> FIREBASE DATA</div>
        <div class="status-dot green"></div>
      </div>
      <div class="firebase-body" id="firebase-body">
        <div class="mono-loading">Reading Firestore...</div>
      </div>
    </div>

    <!-- ── YOLO CONFIDENCE ── -->
    <div class="panel conf-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">🤖</span> YOLO DETECTION — LAST SCAN RESULTS</div>
      </div>
      <div class="conf-body" id="conf-body">
        <div class="mono-loading" style="width:100%">No scan data yet. Run a detection to see confidence scores.</div>
      </div>
