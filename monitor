<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>IntelliChill – System Monitor</title>
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #080f0a;
      --card: #0e1a10;
      --card2: #111f14;
      --border: #1e3322;
      --green: #00ff88;
      --green-dim: #00c86a;
      --green-dark: #003a1f;
      --yellow: #ffd166;
      --red: #ff4d6d;
      --blue: #4cc9f0;
      --muted: #4a6b52;
      --text: #c8e6cc;
      --text-bright: #edfff2;
      --radius: 12px;
      --font-mono: 'JetBrains Mono', monospace;
      --font-ui: 'Outfit', sans-serif;
    }

    * { margin:0; padding:0; box-sizing:border-box; }

    body {
      font-family: var(--font-ui);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      overflow-x: hidden;
    }

    /* Scanline effect */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,255,136,0.015) 2px, rgba(0,255,136,0.015) 4px);
      pointer-events: none;
      z-index: 1000;
    }

    /* ── NAV ── */
    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 58px;
      border-bottom: 1px solid var(--border);
      background: rgba(8,15,10,0.95);
      backdrop-filter: blur(10px);
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .nav-logo {
      font-family: var(--font-mono);
      font-size: 0.95rem;
      font-weight: 700;
      color: var(--green);
      display: flex;
      align-items: center;
      gap: 10px;
      letter-spacing: 0.05em;
    }

    .nav-logo .dot {
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--green);
      animation: pulse 2s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(0,255,136,0.4); }
      50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(0,255,136,0); }
    }

    .nav-right { display:flex; align-items:center; gap:1rem; }

    .nav-time {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--muted);
    }

    .nav-back {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--muted);
      text-decoration: none;
      border: 1px solid var(--border);
      padding: 5px 14px;
      border-radius: 6px;
      transition: all 0.2s;
    }
    .nav-back:hover { color: var(--green); border-color: var(--green); }

    /* ── MAIN LAYOUT ── */
    .monitor-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-rows: auto auto auto;
      gap: 1rem;
      padding: 1.5rem;
      max-width: 1400px;
      margin: 0 auto;
    }

    /* ── PANEL BASE ── */
    .panel {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      overflow: hidden;
    }

    .panel-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 16px;
      border-bottom: 1px solid var(--border);
      background: var(--card2);
    }

    .panel-title {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--muted);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .panel-title .icon { font-size: 0.9rem; }

    .status-dot {
      width: 7px; height: 7px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .status-dot.green  { background: var(--green);  animation: pulse 2s infinite; }
    .status-dot.yellow { background: var(--yellow); animation: pulse 2s infinite; }
    .status-dot.red    { background: var(--red); }
    .status-dot.grey   { background: var(--muted); }

    /* ── SYSTEM FLOW ── */
    .flow-panel { grid-column: 1 / -1; }

    .flow-body {
      padding: 1.5rem 2rem;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 0;
      flex-wrap: nowrap;
      overflow-x: auto;
    }

    .flow-node {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
      min-width: 110px;
    }

    .flow-icon {
      width: 56px; height: 56px;
      border-radius: 14px;
      border: 1px solid var(--border);
      background: var(--card2);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      transition: all 0.3s;
      position: relative;
    }

    .flow-icon.active {
      border-color: var(--green);
      background: var(--green-dark);
      box-shadow: 0 0 20px rgba(0,255,136,0.2);
    }

    .flow-icon.active::after {
      content: '';
      position: absolute;
      inset: -4px;
      border-radius: 17px;
      border: 1px solid rgba(0,255,136,0.3);
      animation: ripple 1.5s ease-out infinite;
    }

    @keyframes ripple {
      0% { opacity: 1; transform: scale(1); }
      100% { opacity: 0; transform: scale(1.3); }
    }

    .flow-label {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      color: var(--muted);
      text-align: center;
      letter-spacing: 0.05em;
    }

    .flow-sublabel {
      font-size: 0.62rem;
      color: #2a4a32;
      font-family: var(--font-mono);
      text-align: center;
    }

    .flow-arrow {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 0 6px;
      min-width: 60px;
    }

    .flow-line {
      height: 2px;
      width: 100%;
      background: var(--border);
      border-radius: 2px;
      position: relative;
      overflow: hidden;
    }

    .flow-line.active::after {
      content: '';
      position: absolute;
      top: 0; left: -100%;
      width: 100%; height: 100%;
      background: linear-gradient(90deg, transparent, var(--green), transparent);
      animation: flowAnim 1.5s linear infinite;
    }

    @keyframes flowAnim {
      to { left: 100%; }
    }

    .flow-ms {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      color: var(--muted);
    }

    /* ── STATS ROW ── */
    .stat-panel { }

    .stat-body {
      padding: 1.2rem 1.4rem;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .stat-value {
      font-family: var(--font-mono);
      font-size: 2rem;
      font-weight: 700;
      color: var(--green);
      line-height: 1;
    }

    .stat-label {
      font-size: 0.78rem;
      color: var(--muted);
      font-family: var(--font-mono);
      letter-spacing: 0.05em;
    }

    .stat-sub {
      font-size: 0.7rem;
      color: #2a4a32;
      font-family: var(--font-mono);
      margin-top: 4px;
    }

    /* ── LOG PANEL ── */
    .log-panel { grid-column: 1 / 3; }

    .log-body {
      padding: 0;
      height: 280px;
      overflow-y: auto;
      font-family: var(--font-mono);
      font-size: 0.75rem;
    }

    .log-body::-webkit-scrollbar { width: 4px; }
    .log-body::-webkit-scrollbar-track { background: var(--card); }
    .log-body::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }

    .log-entry {
      display: flex;
      gap: 12px;
      padding: 7px 16px;
      border-bottom: 1px solid rgba(30,51,34,0.5);
      animation: logSlide 0.3s ease both;
      align-items: flex-start;
    }

    @keyframes logSlide {
      from { opacity:0; transform: translateX(-8px); }
      to   { opacity:1; transform: translateX(0); }
    }

    .log-entry:hover { background: rgba(0,255,136,0.03); }

    .log-time { color: var(--muted); flex-shrink:0; }
    .log-type { flex-shrink:0; width: 50px; }
    .log-type.INFO    { color: var(--blue); }
    .log-type.OK      { color: var(--green); }
    .log-type.WARN    { color: var(--yellow); }
    .log-type.ERROR   { color: var(--red); }
    .log-type.DATA    { color: #c77dff; }
    .log-msg { color: var(--text); flex:1; line-height: 1.4; }
    .log-msg .highlight { color: var(--green); font-weight: 700; }

    /* ── FIREBASE PANEL ── */
    .firebase-panel { grid-column: 3; }

    .firebase-body {
      padding: 0;
      height: 280px;
      overflow-y: auto;
    }

    .firebase-body::-webkit-scrollbar { width: 4px; }
    .firebase-body::-webkit-scrollbar-track { background: var(--card); }
    .firebase-body::-webkit-scrollbar-thumb { background: var(--border); }

    .firebase-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 14px;
      border-bottom: 1px solid rgba(30,51,34,0.5);
      animation: logSlide 0.3s ease both;
    }

    .firebase-item:hover { background: rgba(0,255,136,0.03); }

    .firebase-emoji {
      width: 30px; height: 30px;
      border-radius: 7px;
      background: var(--green-dark);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.95rem;
      flex-shrink: 0;
    }

    .firebase-info { flex:1; min-width:0; }
    .firebase-name {
      font-family: var(--font-mono);
      font-size: 0.78rem;
      color: var(--text-bright);
      font-weight: 700;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .firebase-meta {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--muted);
      margin-top: 2px;
    }

    .firebase-badge {
      font-family: var(--font-mono);
      font-size: 0.62rem;
      padding: 2px 7px;
      border-radius: 4px;
      font-weight: 700;
      flex-shrink: 0;
    }
    .firebase-badge.fresh   { background: rgba(0,255,136,0.15); color: var(--green); }
    .firebase-badge.soon    { background: rgba(255,209,102,0.15); color: var(--yellow); }
    .firebase-badge.expired { background: rgba(255,77,109,0.15); color: var(--red); }

    /* ── CONFIDENCE PANEL ── */
    .conf-panel { grid-column: 1 / -1; }

    .conf-body {
      padding: 1.2rem 1.6rem;
      display: flex;
      align-items: center;
      gap: 1.5rem;
    }

    .conf-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--muted);
      white-space: nowrap;
      width: 80px;
    }

    .conf-bar-wrap {
      flex: 1;
      height: 10px;
      background: var(--card2);
      border-radius: 99px;
      overflow: hidden;
      border: 1px solid var(--border);
    }

    .conf-bar {
      height: 100%;
      border-radius: 99px;
      background: linear-gradient(90deg, var(--green-dim), var(--green));
      transition: width 1s cubic-bezier(0.4,0,0.2,1);
      box-shadow: 0 0 8px rgba(0,255,136,0.4);
    }

    .conf-pct {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      color: var(--green);
      font-weight: 700;
      width: 40px;
      text-align: right;
    }

    /* ── LOADING ── */
    .mono-loading {
      font-family: var(--font-mono);
      font-size: 0.75rem;
      color: var(--muted);
      padding: 2rem;
      text-align: center;
    }

    /* ── SCROLLBAR ── */
    ::-webkit-scrollbar { width: 4px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); }
  </style>
</head>
<body>

  <nav>
    <div class="nav-logo">
      <div class="dot"></div>
      INTELLICHILL // SYSTEM MONITOR
    </div>
    <div class="nav-right">
      <div class="nav-time" id="nav-time">--:--:--</div>
      <a href="index.html" class="nav-back">← Dashboard</a>
    </div>
  </nav>

  <div class="monitor-grid">

    <!-- ── SYSTEM FLOW ── -->
    <div class="panel flow-panel">
      <div class="panel-header">
        <div class="panel-title"><span class="icon">⚡</span> SYSTEM FLOW</div>
        <div class="panel-title"><div class="status-dot green"></div> LIVE</div>
      </div>
      <div class="flow-body" id="flow-body">
        <div class="flow-node">
          <div class="flow-icon" id="node-pi">📷</div>
          <div class="flow-label">PI CAMERA</div>
